# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/rag_db

# JWT secret for authentication
JWT_SECRET=your_random_secret_key

# Backend port
PORT=8000

# Frontend API URL pointing to backend
VITE_API_URL=http://localhost:8000

# OpenAI API key for embeddings
OPENAI_API_KEY=your_openai_api_key

# Google Generative AI SDK key for answering queries
ANTHROPIC_API_KEY=your_anthropic_api_key

# Pinecone API key (if applicable)
PINECONE_API_KEY=your_pinecone_api_key

# PostgreSQL URL for pgvector (if applicable)
POSTGRES_URL=postgresql://username:password@localhost:5432/rag_db