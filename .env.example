# Connection string for PostgreSQL database
DATABASE_URL=postgresql://postgres:password@localhost:5432/rag_db

# Secret key for JWT authentication
JWT_SECRET=your_random_secret_key

# Port for backend service
PORT=8000

# API URL for frontend to communicate with backend
VITE_API_URL=http://localhost:8000

# OpenAI API key for embedding
OPENAI_API_KEY=your_openai_api_key

# Google Generative AI SDK key for answering queries
ANTHROPIC_API_KEY=your_google_sdk_api_key

# Pinecone API key (if applicable, not used in this project)
PINECONE_API_KEY=your_pinecone_api_key

# PostgreSQL URL for pgvector service
POSTGRES_URL=postgresql://postgres:password@localhost:5432/rag_db